# API server port
PORT=4000

# Required in production: random long string used to sign app session tokens.
# Generate one with: openssl rand -base64 48
APP_JWT_SECRET=replace-with-long-random-secret

# Firebase Admin credentials (pick ONE approach)
# 1) Path to your service account JSON file (recommended locally)
FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/firebase-service-account.json
# 2) Inline JSON string for cloud deploys (leave empty locally)
FIREBASE_SERVICE_ACCOUNT_JSON=

# Temporary reviewer bypass for internal QA only.
# Disable in production by setting ALLOW_REVIEWER_BYPASS=false.
ALLOW_REVIEWER_BYPASS=false
REVIEWER_TEST_PHONE_NUMBER=+919999999999
REVIEWER_TEST_OTP=123456
