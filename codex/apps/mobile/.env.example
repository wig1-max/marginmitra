# API base URL used by the Expo app.
# Android emulator local API: http://10.0.2.2:4000/api
# iOS simulator local API: http://localhost:4000/api
# Physical phone local API: http://<your-computer-local-ip>:4000/api
EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:4000/api

# Optional reviewer bypass phone autofill in dev builds.
EXPO_PUBLIC_REVIEWER_TEST_PHONE_NUMBER=+919999999999
